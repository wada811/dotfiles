{
  "env": {
    "COACH_HOLDOUT": "0.3"
  },
  "model": "sonnet",
  "outputStyle": "fable-like",
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "user-context-toolkit@jubilee-works-plugins-local": true
  },
  "extraKnownMarketplaces": {
    "jubilee-works-plugins": {
      "source": {
        "source": "github",
        "repo": "jubilee-works/claude-plugins-playground"
      }
    },
    "jubilee-works-plugins-local": {
      "source": {
        "source": "directory",
        "path": "/Users/andy/Documents/work/repos/claude-plugins-playground"
      }
    }
  },
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/andy/.claude/hooks/coach-report.ts --session-start",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start-compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/andy/.claude/hooks/prompt-coach.ts",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node /Users/andy/.claude/hooks/agency-route.ts",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/compact-warn-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/andy/.claude/hooks/protect-main.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-tool-use-bash.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "touch /Users/andy/Documents/self-evolving-agent/runs/.active 2>/dev/null"
          }
        ]
      }
    ]
  }
}
