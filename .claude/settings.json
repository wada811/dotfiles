{
  "env": {
    "COACH_HOLDOUT": "0.3"
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/andy/.claude/hooks/coach-report.ts --session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/andy/.claude/hooks/prompt-coach.ts",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node /Users/andy/.claude/hooks/agency-route.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/andy/.claude/hooks/protect-main.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "touch /Users/andy/Documents/self-evolving-agent/runs/.active 2>/dev/null"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark"
}
